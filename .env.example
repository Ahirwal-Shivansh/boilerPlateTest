# Server (see readme.md for full env reference)
HOST=127.0.0.1
PORT=8080

# Workers
WORKERS=1
WORKERS_CONFIG=workers.json

# Files (in app data dir unless DATABASE_URL set)
DB_FILENAME=eg_agent.db
LOG_FILENAME=eg_agent.log
# DATABASE_URL=sqlite:///path/to/db  # optional; overrides DB path

# Auto-update version sent to backend
AGENT_VERSION=1.0.0

# Task loading
EG_AGENT_TASKS_DIR=
EG_AGENT_PRELOAD_FILES=verification_db.py
EG_AGENT_PRELOAD_MODULES=verification_db.py,tasks.py

# Tray icon (e.g. icon.icns or icon.png)
EG_AGENT_TRAY_ICON=icon.icns
EG_AGENT_APP_ICON=icon.icns

# Queue/worker (agent URL)
AGENT_SERVER_URL=http://localhost:8080

# Build / installers (see PACKAGING_GUIDE.md)
EG_AGENT_BUILD_ENTRY=
EG_AGENT_BUILD_VERSION=3.0.0
EG_AGENT_PKG_NAME=EG-Agent.pkg
EG_AGENT_APP_NAME=eg-agent
EG_AGENT_CREATE_DESKTOP_SHORTCUT=true
# CODESIGN_IDENTITY=  # macOS code signing (optional)
